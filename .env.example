# =====================================================
# Root .env.example — copy to .env (or set in Vercel)
# =====================================================

# --- Backend ---
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/cropmate?retryWrites=true&w=majority
GEMINI_API_KEY=your_google_generative_ai_key
NODE_ENV=production
CLIENT_ORIGIN=https://your-cropmate.vercel.app

# --- Frontend (Vite — must use VITE_ prefix) ---
# Leave VITE_API_URL empty for production: same-origin /api routes via Vercel rewrite
VITE_API_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
